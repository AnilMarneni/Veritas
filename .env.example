# Veritas Local Environment Variables

# Backend Port Configuration
PORT=5000

# MongoDB Connection
# Replace with local MongoDB Compass string or Docker Compose MongoDB port
MONGODB_URI=mongodb://localhost:27017/veritas

# JWT Secret (for session signing)
JWT_SECRET=veritas_secret_key_for_jwt_session_signing_123

# Cloudinary Integration (for file and image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
